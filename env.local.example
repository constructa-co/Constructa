# Copy this to .env.local and fill in real values
# Ask the project owner for credentials

NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]
SUPABASE_ACCESS_TOKEN=[YOUR_SUPABASE_ACCESS_TOKEN]
OPENAI_API_KEY=[YOUR_OPENAI_API_KEY]

# Sprint 58 P1.9 — observability / error tracking.
# Optional. When set AND `@sentry/nextjs` is installed, all unhandled
# errors caught by the dashboard / projects / global error boundaries
# will be forwarded to Sentry via src/lib/observability.ts. Without
# these, errors still surface to Vercel logs via console.error — you
# just don't get proactive alerts.
# SENTRY_DSN=[YOUR_SENTRY_DSN]
# NEXT_PUBLIC_SENTRY_DSN=[SAME_DSN_IF_YOU_WANT_CLIENT_REPORTING]

# Sprint 59 — Contract Administration daily digest cron.
# REQUIRED for the /api/cron/contract-alerts endpoint to actually run.
# Generate with: openssl rand -hex 32
# Add to Vercel project env vars BEFORE deploying — Vercel cron will
# inject the same value into the Authorization header on every call,
# and the route will reject any request that doesn't carry it.
CRON_SECRET=[GENERATE_A_64_CHAR_HEX_STRING]

# URL the cron-triggered emails will deep-link back to. Defaults to the
# Vercel preview URL when unset.
NEXT_PUBLIC_APP_URL=https://constructa-nu.vercel.app
