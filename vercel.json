{
  "version": 2,
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "constructa.co"
        }
      ],
      "destination": "/landing"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.constructa.co"
        }
      ],
      "destination": "/landing"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/contract-alerts",
      "schedule": "0 7 * * *"
    }
  ],
  "github": {
    "enabled": true,
    "silent": true
  }
}
